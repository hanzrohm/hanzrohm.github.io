@article{HanzrohSearch2024,
  title={Multi Source Consumer Search},
  abstract={In studying consumer search behavior, models typically allow the consumer to learn the utility of a product from a single source of information. In this paper, I develop a model of sequential search where consumers who are uncertain about match values of products can receive noisy signals about them by searching a product at one of multiple sources. In the context of online learning, a consumer can learn about a product's quality typically by reading text information describing the product on a product page (Amazon) or perhaps by visiting a third-party website reviewing the product (i.e. ``cnet.com''). The consumer will consider the cost of accessing each of these sources of information (i.e. time spent searching for information, complexity of information provided) and the benefit to their learning (i.e. depth and unbiased nature of information provided). I study the consumer's optimal choices by building on the framework of Chick and Frazier (2012) to derive the consumer's optimal search rules for each decision they make (what to search, when to stop searching and purchase). I apply the model to a dataset of consumers searching for cameras online and find considerable differences in estimated search costs and learning parameters for consumers searching to learn on e-commerce websites relative to third-party review websites, suggesting that different sources of information matter for consumers' search decisions.},
  author={Hanzroh, Mehtab},
  journal={Working Paper, Presenting at CEA 2024},
  year={2024}
}

@article{HanzrohPred2024,
  title           = {Using Search Data to Crowd-source Unobserved Substitution Patterns for Demand Prediction},
  abstract        = {This paper develops methodology to enhance the accuracy of predictive demand models that rely on clickstream (or search) data, particularly in the context where only a limited set of product characteristics are observable. Traditional models often utilize the history of products browsed by consumers for constructing explanatory variables, and measure the relationship between these previously-browsed products and the target product through distance in a characteristic space. However, in many instances characteristics data are not available. To address this limitation, I propose a novel pairwise substitution measure derived from the aggregation of product searches across \textit{all} consumers. This approach crowdsources the entirety of consumers' search behaviors to infer substitution patterns which aides in predicting consumer purchases. I estimate the model using a clickstream dataset from a large UK eCommerce platform, and show that incorporating this crowdsourced information on substitution patterns into a demand prediction model leads to effective predictions even without characteristics data. The models are estimated using both logistic regression and a state-of-the-art machine learning algorithm, LightGBM, and I show that the LightGBM estimation method performs better than logistic regression, and is able to take better advantage of the crowdsourced substitution patterns.},
  author          = {Hanzroh, Mehtab},
  journal         = {Working Paper, Presented at CEA 2023},
  year            = {2024}
}